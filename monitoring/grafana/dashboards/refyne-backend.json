      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "rate(refyne_http_requests_total[5m])",
          "refId": "A",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "title": "Request Rate (5m avg)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["last", "mean"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "single"}
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(refyne_http_request_duration_seconds_bucket[5m]))",
          "refId": "A",
          "legendFormat": "P95 {{method}} {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(refyne_http_request_duration_seconds_bucket[5m]))",
          "refId": "B",
          "legendFormat": "P99 {{method}} {{endpoint}}"
        }
      ],
      "title": "Request Latency (P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
