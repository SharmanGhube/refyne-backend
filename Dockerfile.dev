# ─────────────────────────────────────────────
# Dev image – uses Air for hot reload
# Does NOT run wire; wire_gen.go must already
# exist (generated locally or committed).
# ─────────────────────────────────────────────
FROM golang:1.24-alpine

# Build tools + git (needed for some go modules)
RUN apk add --no-cache git ca-certificates tzdata curl make

WORKDIR /app

# Install wire (for code generation)
RUN go install github.com/google/wire/cmd/wire@latest

# Install Air (hot reload) — pin to a version compatible with Go 1.24
RUN go install github.com/air-verse/air@v1.61.5

# Copy dependency manifests and download (cached layer)
COPY go.mod go.sum ./
RUN go mod download

# Copy source — volume mount will overlay this at runtime
COPY . .

EXPOSE 8080

# Air reads .air.toml from the working directory
CMD ["air", "-c", ".air.toml"]
